{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Colima Desktop",
  "version": "0.1.0",
  "identifier": "com.yoonhogo.colima-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Colima Desktop",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE3NDAzREMxMjYzNjJBQjEKUldTeEtqWW13VDFBcDFGWTRia05GSVV0T0lMQWIrRGMvK0hHcHA4d3cxZnIybm9UNW1jRGo5VSsK",
      "endpoints": [
        "https://github.com/yoonhoGo/colima-desktop/releases/latest/download/latest.json"
      ]
    }
  }
}
